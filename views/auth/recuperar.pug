extends ../layout/index
    
block contenido
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center.text-lime-400 Bienes
            span.font-normal.text-black Raíces 
        h2.text-center.text-2xl.font-normal.text-black= pagina

        //- Contenedor de Notificaciones (Fijo abajo a la derecha)
        #notification-container(class="fixed bottom-5 right-5 z-50 flex flex-col gap-3 w-full max-w-sm px-4")
            if errores
                each error in errores
                    div(class="notification bg-red-600 text-white p-4 rounded-xl shadow-2xl relative overflow-hidden flex items-center gap-3 border-l-4 border-red-800" role="alert")
                        svg.h-6.w-6.flex-shrink-0(fill="none" viewBox="0 0 24 24" stroke="currentColor")
                            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z")
                        p.text-xs.font-bold.uppercase.tracking-wide= error.msg
                        //- Barra de tiempo en color claro (red-200)
                        div(class="absolute bottom-0 left-0 h-1 bg-red-200 animate-shrink")
            
            //- Por si envías un mensaje de confirmación (ej: "Correo enviado")
            if mensaje 
                div(class="notification bg-emerald-600 text-white p-4 rounded-xl shadow-2xl relative overflow-hidden flex items-center gap-3 border-l-4 border-emerald-800" role="alert")
                    svg.h-6.w-6.flex-shrink-0(fill="none" viewBox="0 0 24 24" stroke="currentColor")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z")
                    p.text-xs.font-bold.uppercase.tracking-wide= mensaje
                    //- Barra de tiempo en color claro (emerald-200)
                    div(class="absolute bottom-0 left-0 h-1 bg-emerald-200 animate-shrink")

    .mt-8.mx-auto.max-w-xl.pb-5
        .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
            form.space-y-5(method="POST" action="/auth/recuperar" noValidate) 
                input(type="hidden" name="_csrf" value=csrfToken)
                
                div.px-5
                    label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="emailUsuario") Correo electrónico:
                    input#emailUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400(placeholder="p.e.: usuario@dominio.com" name="emailUsuario" type="email")

                input(class="w-full bg-lime-400 hover:bg-lime-500 hover:transition text-gray-500 hover:text-white font-bold py-3 cursor-pointer shadow-lg rounded-4xl uppercase" type="submit" value="Enviar correo de recuperación")

                div.flex.items-center.justify-between.pt-3.px-5
                    a(class="text-gray-500 text-sm hover:decoration-lime-400 hover:underline transition decoration-2" href="/auth/login") ¿Ya tienes cuenta? Inicia sesión
                    a(class="text-gray-500 text-sm hover:decoration-lime-400 hover:underline transition decoration-2" href="/auth/registro") ¿No tienes cuenta? Regístrate

//- Bloque de Scripts para controlar la animación
block scripts
    script.
        document.addEventListener('DOMContentLoaded', () => {
            const notifications = document.querySelectorAll('.notification');
            
            notifications.forEach((notif, index) => {
                // Aparecer (Slide in)
                setTimeout(() => {
                    notif.classList.add('show');
                }, index * 200);

                // Desaparecer automáticamente tras 5 segundos
                setTimeout(() => {
                    notif.classList.remove('show');
                    setTimeout(() => notif.remove(), 500);
                }, 5000);
            });
        });