extends ../layout/index

block contenido
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center.text-lime-400 Bienes
            span.font-normal.text-black Raíces 
        h2.text-center.text-2xl.font-normal.text-black= pagina

        //- Contenedor de Notificaciones (Toast)
        #notification-container(class="fixed bottom-5 right-5 z-50 flex flex-col gap-3 w-full max-w-sm px-4")
            if errores
                each error in errores
                    div(class="notification bg-red-600 text-white p-4 rounded-xl shadow-2xl relative overflow-hidden flex items-center gap-3 border-l-4 border-red-800" role="alert")
                        svg.h-6.w-6.flex-shrink-0(fill="none" viewBox="0 0 24 24" stroke="currentColor")
                            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z")
                        p.text-xs.font-bold.uppercase.tracking-wide= error.msg
                        div(class="absolute bottom-0 left-0 h-1 bg-red-200 animate-shrink")
            
            if mensaje 
                div(class="notification bg-emerald-600 text-white p-4 rounded-xl shadow-2xl relative overflow-hidden flex items-center gap-3 border-l-4 border-emerald-800" role="alert")
                    svg.h-6.w-6.flex-shrink-0(fill="none" viewBox="0 0 24 24" stroke="currentColor")
                        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z")
                    p.text-xs.font-bold.uppercase.tracking-wide= mensaje
                    div(class="absolute bottom-0 left-0 h-1 bg-emerald-300/50 animate-shrink")

    .mt-8.mx-auto.max-w-xl.pb-5
        .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
            form.space-y-5(method="POST" action="/auth/login" noValidate) 
                input(type="hidden" name="_csrf" value=csrfToken)

                div.px-5
                    label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="emailUsuario") Correo electrónico:
                    input#emailUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400(placeholder="p.e.: usuario@dominio.com" name="emailUsuario" type="email" value= usuario ? usuario.emailUsuario : '')

                div.px-5
                    label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="passwordUsuario") Contraseña:
                    input#passwordUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400(placeholder="Por lo menos 8 caracteres" name="passwordUsuario" type="password")

                div.px-5.flex.items-center.gap-2.mt-1
                    input#verP1(type="checkbox" class="cursor-pointer" onclick="document.getElementById('passwordUsuario').type = this.checked ? 'text' : 'password'")
                    label.text-xs.text-gray-500.cursor-pointer(for="verP1") Mostrar contraseña

                div.px-5
                    input(class="w-full bg-lime-400 hover:bg-lime-500 hover:transition text-gray-500 hover:text-white font-bold py-3 cursor-pointer shadow-lg rounded-xl uppercase" type="submit" value="Iniciar Sesión")

            //- SECCIÓN DE REDES SOCIALES
            div.mt-10.px-5
                div.relative
                    div.absolute.inset-0.flex.items-center
                        div.w-full.border-t.border-gray-300
                    div.relative.flex.justify-center.text-sm
                        span.px-2.bg-white.text-gray-500 O ingresa con

                div.mt-6.grid.grid-cols-2.gap-3
                    a(href="/auth/github" class="flex items-center justify-center gap-2 bg-gray-800 hover:bg-gray-900 text-white font-bold py-2 px-4 rounded-xl transition-all shadow-md hover:shadow-lg")
                        svg.h-5.w-5(fill="currentColor" viewBox="0 0 24 24")
                            path(d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z")
                        span GitHub
                    
                    a(href="/auth/discord" class="flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded-xl transition-all shadow-md hover:shadow-lg")
                        svg.h-5.w-5(fill="currentColor" viewBox="0 0 24 24")
                            path(d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z")
                        span Discord

            div.flex.items-center.justify-between.pt-10.px-5
                a(class="text-gray-500 text-sm hover:decoration-lime-400 hover:underline transition decoration-2" href="/auth/registro") ¿No tienes cuenta? Regístrate
                a(class="text-gray-500 text-sm hover:decoration-lime-400 hover:underline transition decoration-2" href="/auth/recuperar") ¿Olvidaste tu contraseña?

block scripts
    script.
        document.addEventListener('DOMContentLoaded', () => {
            const notifications = document.querySelectorAll('.notification');
            
            notifications.forEach((notif, index) => {
                setTimeout(() => {
                    notif.classList.add('show');
                }, index * 200);

                setTimeout(() => {
                    notif.classList.remove('show');
                    setTimeout(() => notif.remove(), 500);
                }, 5000);
            });
        });