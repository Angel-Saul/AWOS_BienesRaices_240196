extends ../layout/index
    
block contenido
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center.text-lime-400 Bienes
            span.font-normal.text-black Raíces 
        h2.text-center.text-2xl.font-normal.text-black= pagina

        .mt-8.mx-auto.max-w-xl.pb-5
            //- El contenedor mantiene su redondeado simétrico (rounded-2xl)
            .bg-emerald-50.py-8.px-6.shadow-2xl.rounded-2xl.border-l-8.border-emerald-500.relative.overflow-hidden
                
                //- Título de la página
                h2.text-center.text-2xl.font-black.text-emerald-800.mb-6.uppercase= pagina

                //- Mensaje principal
                p.text-base.font-bold.text-center.text-emerald-700.my-10.tracking-wide= mensaje

                //- Botón dinámico
                if buttonVisibility
                    div.flex.justify-center.mt-5
                        a(class="w-3/4 bg-emerald-500 text-white hover:bg-emerald-600 font-bold py-3 cursor-pointer shadow-lg hover:shadow-xl uppercase rounded-xl transition-all duration-300 text-center block"
                            href=buttonURL)= buttonText